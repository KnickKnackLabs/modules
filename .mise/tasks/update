#!/usr/bin/env bash
#MISE description="Pull latest and update pin for module(s)"
#MISE dir="{{config_root}}"
#USAGE arg "[name]" help="Module name (omit to update all)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_jq
require_initialized

update_module() {
  local name="$1"
  local entry
  entry="$(manifest_get "$name")" || { echo "Error: module '$name' not found" >&2; return 1; }

  local url path pin
  url="$(echo "$entry" | jq -r '.url')"
  path="$(echo "$entry" | jq -r '.path')"
  pin="$(echo "$entry" | jq -r '.pin')"
  local mod_path="$TARGET_DIR/$path"

  if [ ! -d "$mod_path/.git" ]; then
    echo "  $name: not cloned (run: modules init)" >&2
    return 1
  fi

  echo "  $name: pulling..."

  # If HEAD is detached (e.g., after init), checkout the default branch first
  if ! git -C "$mod_path" symbolic-ref -q HEAD &>/dev/null; then
    local default_branch
    default_branch="$(git -C "$mod_path" rev-parse --abbrev-ref origin/HEAD 2>/dev/null | sed 's|^origin/||')"
    if [ -z "$default_branch" ] || [ "$default_branch" = "HEAD" ]; then
      # Fallback: try main, then master
      if git -C "$mod_path" show-ref --verify --quiet refs/remotes/origin/main; then
        default_branch="main"
      elif git -C "$mod_path" show-ref --verify --quiet refs/remotes/origin/master; then
        default_branch="master"
      else
        echo "  $name: cannot determine default branch" >&2
        return 1
      fi
    fi
    git -C "$mod_path" checkout "$default_branch" 2>&1
  fi

  git -C "$mod_path" pull --ff-only 2>&1

  local new_pin
  new_pin="$(git -C "$mod_path" rev-parse HEAD)"

  if [ "$new_pin" = "$pin" ]; then
    echo "  $name: already up to date (${pin:0:12})"
  else
    manifest_set "$name" "$url" "$path" "$new_pin"
    git -C "$TARGET_DIR" add "$mod_path" "$MANIFEST"
    echo "  $name: updated ${pin:0:12} → ${new_pin:0:12}"
  fi
}

if [ -n "${usage_name:-}" ]; then
  update_module "$usage_name"
else
  while IFS= read -r name; do
    update_module "$name" || true
  done < <(manifest_names)
fi
