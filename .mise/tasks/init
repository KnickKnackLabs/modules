#!/usr/bin/env bash
#MISE description="Clone and checkout all modules from the manifest"
#MISE dir="{{config_root}}"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_jq
require_initialized

manifest="$(manifest_read)"
count="$(echo "$manifest" | jq 'length')"

if [ "$count" -eq 0 ]; then
  echo "No modules to initialize."
  exit 0
fi

errors=0

echo "$manifest" | jq -r 'to_entries[] | "\(.key)\t\(.value.url)\t\(.value.path)\t\(.value.pin)"' | \
while IFS=$'\t' read -r name url path pin; do
  mod_path="$TARGET_DIR/$path"

  if [ -d "$mod_path/.git" ]; then
    echo "  $name: already cloned"
    continue
  fi

  echo "  $name: cloning $url → $path"

  # Clean up any empty directory left by git
  if [ -d "$mod_path" ]; then
    rmdir "$mod_path" 2>/dev/null || true
  fi

  if ! git clone "$url" "$mod_path" 2>&1; then
    echo "  $name: clone failed" >&2
    errors=$((errors + 1))
    continue
  fi

  git -C "$mod_path" checkout "$pin" 2>&1

  # Verify we're at the right commit
  actual="$(git -C "$mod_path" rev-parse HEAD)"
  if [ "$actual" != "$pin" ]; then
    echo "  $name: warning — expected $pin, at $actual" >&2
  fi
done

if [ "$errors" -gt 0 ]; then
  echo "$errors module(s) failed to initialize" >&2
  exit 1
fi
