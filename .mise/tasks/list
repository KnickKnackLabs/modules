#!/usr/bin/env bash
#MISE description="List modules"
#MISE dir="{{config_root}}"
#USAGE flag "--json" help="Output as JSON"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_initialized

if [ "$(manifest_count)" -eq 0 ]; then
  echo "No modules. Use 'modules add <url>' to add one."
  exit 0
fi

if [ "${usage_json:-}" = "true" ]; then
  # Emit as JSON: {name: {url, pin}}, to preserve the old --json schema.
  # Build via jq -nR so URLs/names containing quotes, backslashes, or control
  # characters are safely escaped (awk-based string interpolation is unsafe).
  jq -nR '
    [ inputs
      | select(length > 0)
      | split("\t")
      | { (.[0]): { url: .[1], pin: .[2] } }
    ]
    | add // {}
  ' "$MANIFEST"
  exit 0
fi

{
  printf "Name\tURL\tPin\n"
  awk -F'\t' '{ printf "%s\t%s\t%.12s\n", $1, $2, $3 }' "$MANIFEST"
} | gum table --print --separator "	"
