#!/usr/bin/env bash
#MISE description="Initialize modules in the current repo"
#MISE dir="{{config_root}}"
#USAGE flag "--path <path>" help="Clone-root path relative to repo (default: modules)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/hooks.sh"

require_git
require_jq

# ── Resolve and validate requested path ──────────────────────

requested_path="${usage_path:-}"
if [ -z "$requested_path" ]; then
  requested_path="$(clones_path_rel)"
fi

if [ -z "$requested_path" ] \
  || [[ "$requested_path" = /* ]] \
  || [[ "$requested_path" = *".."* ]] \
  || [[ "$requested_path" = .* ]]; then
  echo "Error: invalid --path: '$requested_path'" >&2
  echo "Path must be relative, not start with a dot, and not contain '..'" >&2
  exit 1
fi

requested_path="${requested_path%/}"

full_path="$TARGET_DIR/$requested_path"
if [ -d "$full_path" ] && [ -n "$(ls -A "$full_path" 2>/dev/null)" ] && [ ! -f "$CONFIG" ]; then
  echo "Error: '$requested_path/' already exists and is not empty." >&2
  echo "Pass --path <other-path> to use a different location." >&2
  exit 1
fi

# ── Create .modules/ with empty manifest + config ────────────

mkdir -p "$MODULES_DIR"

# Empty manifest: no lines. Touch is enough.
if [ ! -f "$MANIFEST" ]; then
  : > "$MANIFEST"
fi

# Config: JSON object with 'path' and 'version'. The version declares the
# modules layout format so clients can refuse to operate on repos they
# don't understand (see require_initialized).
jq -n --arg p "$requested_path" --arg v "$MODULES_LAYOUT_VERSION" \
  '{"path": $p, "version": $v}' > "$CONFIG"

CLONES_PATH_REL="$(clones_path_rel)"

# ── Gitignore the clones dir ─────────────────────────────────

GITIGNORE="$TARGET_DIR/.gitignore"
gitignore_entry="$CLONES_PATH_REL/"
if [ ! -f "$GITIGNORE" ] || ! grep -qxF "$gitignore_entry" "$GITIGNORE"; then
  if [ -f "$GITIGNORE" ] && [ -n "$(tail -c1 "$GITIGNORE")" ]; then
    printf '\n' >> "$GITIGNORE"
  fi
  echo "$gitignore_entry" >> "$GITIGNORE"
fi

# ── Encryption: auto-detect via rudi ──────────────────────────

if command -v rudi &>/dev/null; then
  rudi_status="$(cd "$TARGET_DIR" && rudi status --json)" || {
    echo "Error: rudi status --json failed" >&2
    exit 1
  }
  if echo "$rudi_status" | jq -e '.initialized == true' &>/dev/null; then
    (cd "$TARGET_DIR" && rudi assign "$MANIFEST_REL") || {
      echo "Error: rudi assign failed" >&2
      exit 1
    }
    echo "  encryption: manifest assigned to git-crypt"
  fi
fi

# ── Pre-commit hooks ──────────────────────────────────────────

HOOKS_SRC="$MISE_CONFIG_ROOT/hooks"
HOOKS_DST="$TARGET_DIR/.git/hooks"

if [ ! -x "$HOOKS_DST/pre-commit" ]; then
  cp "$HOOKS_SRC/dispatcher" "$HOOKS_DST/pre-commit"
  chmod +x "$HOOKS_DST/pre-commit"
fi

mkdir -p "$HOOKS_DST/pre-commit.d"
for hook in gitmodules-guard manifest-encryption; do
  cp "$HOOKS_SRC/$hook" "$HOOKS_DST/pre-commit.d/$hook"
  chmod +x "$HOOKS_DST/pre-commit.d/$hook"
done

rm -f "$HOOKS_DST/pre-commit.d/path-obfuscation"

# ── Manifest merge driver ────────────────────────────────
# Required to safely merge concurrent pin bumps (notes#48-class bug).

install_manifest_merge_driver

# Stage the manifest, config, gitignore, and gitattributes
git -C "$TARGET_DIR" add "$MANIFEST" "$CONFIG" "$GITIGNORE" "$TARGET_DIR/.gitattributes" 2>/dev/null || true

echo "Initialized modules in $TARGET_DIR"
echo "  manifest:  $MANIFEST_REL"
echo "  config:    $CONFIG_REL"
echo "  clones at: $CLONES_PATH_REL/"
echo "  hooks: pre-commit dispatcher + 2 guards"
echo "  merge:    .modules/manifest (union merge driver)"
